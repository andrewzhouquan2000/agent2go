// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  teams         Team[]
  tasks         Task[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Agent {
  id          String   @id @default(cuid())
  name        String   @unique  // 专家名称，如 xiaohongshu-specialist
  displayName String   // 显示名称，如 "小红书营销专家"
  description String   // 专家描述
  category    String   // 专家分类，如 "营销与增长"
  capabilities String  // JSON string array，能力标签
  avatar      String?  // 头像 URL
  goal        String?  // CrewAI 角色目标
  backstory   String?  // CrewAI 角色背景故事
  teams       TeamAgent[]
  tasks       Task[]
  scenarios   ScenarioAgent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Team {
  id        String      @id @default(cuid())
  name      String
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  agents    TeamAgent[]
  tasks     Task[]
  createdAt DateTime    @default(now())
}

model TeamAgent {
  id        String @id @default(cuid())
  teamId    String
  agentId   String
  team      Team   @relation(fields: [teamId], references: [id])
  agent     Agent  @relation(fields: [agentId], references: [id])

  @@unique([teamId, agentId])
}

model Scenario {
  id          String   @id @default(cuid())
  name        String   @unique  // 场景名称，如 "小红书营销"
  displayName String   // 显示名称
  description String   // 场景描述
  category    String   // 场景分类，如 "营销"
  estimatedCost Int    // 预计成本（元）
  estimatedDays Int    // 预计天数
  kpi         String?  // 预期效果
  agents      ScenarioAgent[]
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScenarioAgent {
  id         String   @id @default(cuid())
  scenarioId String
  agentId    String
  priority   Int      @default(1)  // 推荐优先级，1=核心，2=可选
  scenario   Scenario @relation(fields: [scenarioId], references: [id])
  agent      Agent    @relation(fields: [agentId], references: [id])

  @@unique([scenarioId, agentId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("pending") // pending, in_progress, review, completed, failed
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  scenarioId  String?
  scenario    Scenario? @relation(fields: [scenarioId], references: [id])
  result      String?
  crewaiFlowId String? // CrewAI Flow 执行 ID
  metadata    String?  // JSON metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Session 模型：任务会话（群聊上下文）
model TaskSession {
  id          String   @id @default(cuid())
  taskId      String   @unique  // 关联的 Task ID
  scenarioId  String   // 场景 ID
  status      String   @default("active") // active, completed, failed
  crewaiLogs  String?  // JSON string，CrewAI 执行日志
  result      String?  // 最终交付结果
  messages    Message[] // 群聊消息
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Message 模型：群聊消息
model Message {
  id          String     @id @default(cuid())
  sessionId   String     // TaskSession ID
  session     TaskSession @relation(fields: [sessionId], references: [id])
  senderType  String     // "agent" | "user"
  senderName  String     // 发送者名称
  senderRole  String?    // 发送者角色（仅 agent）
  content     String     // 消息内容
  metadata    String?    // JSON metadata（如工具调用结果）
  createdAt   DateTime   @default(now())

  @@index([sessionId])
}
