generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  integrations  Integration[]
  rateLimits    RateLimit[]
  sessions      Session[]
  subscription  Subscription?
  tasks         Task[]
  teams         Team[]
  usageRecords  UserUsage[]
  workflows     Workflow[]
}

model Agent {
  id            String          @id @default(cuid())
  name          String          @unique
  displayName   String
  description   String
  category      String
  capabilities  String
  avatar        String?
  goal          String?
  backstory     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  scenarios     ScenarioAgent[]
  tasks         Task[]
  teams         TeamAgent[]
  workflowTasks WorkflowTask[]
}

model Team {
  id        String      @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime    @default(now())
  tasks     Task[]
  user      User        @relation(fields: [userId], references: [id])
  agents    TeamAgent[]
}

model TeamAgent {
  id      String @id @default(cuid())
  teamId  String
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])
  team    Team   @relation(fields: [teamId], references: [id])

  @@unique([teamId, agentId])
}

model Scenario {
  id            String          @id @default(cuid())
  name          String          @unique
  displayName   String
  description   String
  category      String
  estimatedCost Int
  estimatedDays Int
  kpi           String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  agents        ScenarioAgent[]
  tasks         Task[]
}

model ScenarioAgent {
  id         String   @id @default(cuid())
  scenarioId String
  agentId    String
  priority   Int      @default(1)
  agent      Agent    @relation(fields: [agentId], references: [id])
  scenario   Scenario @relation(fields: [scenarioId], references: [id])

  @@unique([scenarioId, agentId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String
  status       TaskStatus @default(pending)
  userId       String
  agentId      String?
  teamId       String?
  scenarioId   String?
  result       String?
  crewaiFlowId String?
  metadata     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  input        Json?
  output       Json?
  parentId     String?
  workflowId   String?
  user         User       @relation(fields: [userId], references: [id])
  agent        Agent?     @relation(fields: [agentId], references: [id])
  team         Team?      @relation(fields: [teamId], references: [id])
  scenario     Scenario?  @relation(fields: [scenarioId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TaskSession {
  id         String    @id @default(cuid())
  taskId     String    @unique
  scenarioId String
  status     String    @default("active")
  crewaiLogs String?
  result     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   Message[]
}

model Message {
  id         String      @id @default(cuid())
  sessionId  String
  senderType String
  senderName String
  senderRole String?
  content    String
  metadata   String?
  createdAt  DateTime    @default(now())
  session    TaskSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  userId      String
  status      String         @default("draft")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id])
  tasks       WorkflowTask[]
}

model WorkflowTask {
  id         String   @id @default(cuid())
  workflowId String
  agentId    String
  order      Int      @default(0)
  config     String?
  createdAt  DateTime @default(now())
  agent      Agent    @relation(fields: [agentId], references: [id])
  workflow   Workflow @relation(fields: [workflowId], references: [id])
}

model Integration {
  id          String          @id @default(cuid())
  userId      String
  type        IntegrationType
  credentials Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  config      String
  createdAt   DateTime @default(now())
}

model UserUsage {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  periodStart DateTime
  periodEnd   DateTime
  taskCount   Int      @default(0)
  tokenCount  Int      @default(0)
  costCents   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String    @default("free")
  status               String    @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])
}

model RateLimit {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  window    String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, endpoint, window])
}

enum TaskStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum IntegrationType {
  OpenAI
  Anthropic
  Stripe
  Shopify
  Google
  Microsoft
  Slack
  GitHub
  Custom
}
